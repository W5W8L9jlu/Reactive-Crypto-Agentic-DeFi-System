# Reactive CLI runtime
REACTIVE_CLI_DB_PATH=./tmp/cli_state.db

# Optional advanced override (request-file mode)
# REACTIVE_MAINCHAIN_REQUEST_JSON=./tmp/mainchain_request.json
# REACTIVE_TRIGGER_OBSERVED_OUT=1000000000000000000

# Runtime environment policy
# - development: allows local proxy (localhost/127.0.0.1)
# - production: forbids local proxy forwarding for LLM channel
REACTIVE_ENV=development

# Required for decision runtime (user-provided values, do not hardcode)
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Optional proxy settings
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=

# Required for on-chain runtime routes:
# - decision run
# - execution force-close
SEPOLIA_RPC_URL=
# BASE_SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
REACTIVE_INVESTMENT_COMPILER_ADDRESS=

# Optional when using non-default artifact path
# REACTIVE_INVESTMENT_COMPILER_ARTIFACT=./backend/contracts/out/ReactiveInvestmentCompiler.sol/ReactiveInvestmentCompiler.json
